{
  channels: {
    slack: {
      enabled: true,
      mode: "socket",
      appToken: {
        source: "env",
        provider: "default",
        id: "SLACK_APP_TOKEN"
      },
      botToken: {
        source: "env",
        provider: "default",
        id: "SLACK_BOT_TOKEN"
      }
    }
  }
}